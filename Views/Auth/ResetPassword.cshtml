@model Obeli_K.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Réinitialiser le mot de passe";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="auth-card">
    <div class="text-center mb-4">
        <i class="fas fa-lock fa-3x text-primary mb-3"></i>
        <h2 class="text-primary">Nouveau mot de passe</h2>
        <p class="text-muted">Créez votre nouveau mot de passe</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        
        <input asp-for="Token" type="hidden" />
        <input asp-for="Matricule" type="hidden" />

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">
                <i class="fas fa-key me-1"></i>
                Nouveau mot de passe
            </label>
            <input asp-for="NewPassword" type="password" class="form-control form-control-lg" placeholder="Minimum 6 caractères" autofocus />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label">
                <i class="fas fa-check-circle me-1"></i>
                Confirmer le mot de passe
            </label>
            <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" placeholder="Retapez le mot de passe" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="alert alert-info mb-3">
            <i class="fas fa-shield-alt me-2"></i>
            <strong>Sécurité:</strong>
            <ul class="small mb-0 mt-2">
                <li>Minimum 6 caractères</li>
                <li>Utilisez des lettres et des chiffres</li>
                <li>Évitez les mots de passe trop simples</li>
            </ul>
        </div>

        <div class="d-grid gap-2 mb-3">
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="fas fa-save me-2"></i>
                Réinitialiser le mot de passe
            </button>
        </div>

        <div class="text-center">
            <a asp-action="Login" class="text-decoration-none">
                <i class="fas fa-arrow-left me-1"></i>
                Retour à la connexion
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
